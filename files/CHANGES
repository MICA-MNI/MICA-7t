## 2026-05-27

### Generate `_scans.tsv` for each subject/session

> PATCH database: acq_time in _scans.tsv files (Fixed on version v3.0)

For every `sub-*/ses-*` directory, create a `_scans.tsv` file listing all `.nii.gz` files and their `AcquisitionTime` extracted from the corresponding `.json` sidecar. Directories with no `.nii.gz` files are skipped.
acq_time were formatted according to the BIDS specification (YYYY-MM-DDTHH:mm:ss).

```bash
cd ${data_dir}/sorted/
echo "sub,ses,AcquisitionDate" > pni_AcquisitionDate.csv
for dir in sub*_ses*; do
    sub=${dir%%_*}
    ses=${dir#*_}
    dcm=$(printf '%s\n' "$dir"/dicoms_sorted/*/* | head -n 1)
    [[ -f "$dcm" ]] || {
        echo "No DICOM found in $dir" >&2
        continue
    }
    echo "$dir: $dcm"
    AcquisitionDate=$(
        dcmdump +P AcquisitionDate "$dcm" 2>/dev/null |
        awk -F'[][]' '{print $2}'
    )
    echo "$sub,$ses,$AcquisitionDate" >> pni_AcquisitionDate.csv
done
```

```bash
cd ${bids_dir}
declare -A date
while IFS=, read -r sub ses acq; do
    [[ $sub == sub ]] && continue
    date["$sub,$ses"]="${acq:0:4}-${acq:4:2}-${acq:6:2}"
done < pni_AcquisitionDate.csv

for subses in sub-*/ses-*; do
    sub=${subses%%/*}
    ses=${subses##*/}

    mapfile -t niis < <(find "$subses" -type f -name '*.nii.gz')
    [ ${#niis[@]} -eq 0 ] && continue

    {
    printf "filename\tacq_time\n"
    for nii in "${niis[@]}"; do
        IFS=':.' read -r h m s _ < <(jq -r '.AcquisitionTime' "${nii%.nii.gz}.json")
        printf "%s\t%sT%02d:%02d:%02d\n" \
            "${nii#"$subses"/}" \
            "${date["$sub,$ses"]}" \
            "$h" "$m" "$s"
    done
} | tee "$subses/${sub}_${ses}_scans.tsv"
done
```

## 2026-05-26

### Add Mandatory keys to MP2RAGE json
    RepetitionTimeExcitation: required
    RepetitionTimePreparation: required
    NumberShots: required

```bash
bids_dir="/data_/mica3/BIDS_PNI/rawdata"
for subses in sub*/ses*; do
    sub=$(echo "$subses" | cut -d'/' -f1)
    ses=$(echo "$subses" | cut -d'/' -f2)
    mp2rage_keys.py -sub ${sub/sub-/} -ses ${ses/ses-} -bids ${bids_dir}
done
```

